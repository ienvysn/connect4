{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://connect4-production.up.railway.app/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://connect4-production.up.railway.app/socket.io/$1"
    },
    {
      "source": "/game",
      "destination": "/game.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1",
      "check": true
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": true
}
